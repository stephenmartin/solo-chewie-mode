{{!-- OpenSwim Explainer --}}
<section class="tint-section">
  <div class="container">
    <div class="explainer-grid">
      <div style="order: 2;">
        <div class="eyebrow">The problem</div>
        <h2>Getting audio onto OpenSwim is a chore.</h2>
        <p>Shokz OpenSwim and OpenSwim Pro store music on 4 GB of internal flash with no Bluetooth and no streaming. To load audio, you plug them into your Mac and manually drag files in Finder. That means exporting from Apple Music, renaming files that break on FAT32, and hoping nothing corrupts mid-transfer.</p>
        <p>Conduxor replaces that entire workflow. It reads your Apple Music library directly, sanitizes filenames automatically, tracks copy progress, and skips duplicates. Copy audio to your OpenSwim headphones in a few clicks instead of a dozen steps.</p>
      </div>
      <div class="explainer-visual" aria-label="Drag and drop illustration" style="padding: 48px 40px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0;">
        <svg viewBox="0 0 320 240" fill="none" style="width: 100%; max-width: 380px; height: auto;">
          {{!-- Finder window background --}}
          <rect x="10" y="10" width="200" height="160" rx="8" fill="var(--win-bg)" stroke="var(--win-line)" stroke-width="1.2"/>
          <rect x="10" y="10" width="200" height="24" rx="8" fill="var(--win-side)" stroke="var(--win-line)" stroke-width="1.2"/>
          <rect x="10" y="26" width="200" height="8" fill="var(--win-side)"/>
          <circle cx="24" cy="22" r="4" fill="#ff5f57"/>
          <circle cx="36" cy="22" r="4" fill="#febc2e"/>
          <circle cx="48" cy="22" r="4" fill="#28c840"/>
          <text x="110" y="25" text-anchor="middle" fill="var(--ink-3)" font-size="9" font-family="'Inter', sans-serif" font-weight="500">Finder</text>
          {{!-- File rows --}}
          <rect x="24" y="44" width="14" height="14" rx="2" fill="var(--line)" stroke="var(--win-line)" stroke-width="0.6"/>
          <rect x="44" y="47" width="80" height="3" rx="1.5" fill="var(--ink-4)" opacity="0.5"/>
          <rect x="44" y="53" width="50" height="2.5" rx="1.25" fill="var(--line)"/>
          <rect x="24" y="66" width="14" height="14" rx="2" fill="var(--line)" stroke="var(--win-line)" stroke-width="0.6"/>
          <rect x="44" y="69" width="70" height="3" rx="1.5" fill="var(--ink-4)" opacity="0.5"/>
          <rect x="44" y="75" width="55" height="2.5" rx="1.25" fill="var(--line)"/>
          <rect x="24" y="88" width="14" height="14" rx="2" fill="var(--line)" stroke="var(--win-line)" stroke-width="0.6"/>
          <rect x="44" y="91" width="85" height="3" rx="1.5" fill="var(--ink-4)" opacity="0.5"/>
          <rect x="44" y="97" width="45" height="2.5" rx="1.25" fill="var(--line)"/>
          <rect x="24" y="110" width="14" height="14" rx="2" fill="var(--line)" stroke="var(--win-line)" stroke-width="0.6"/>
          <rect x="44" y="113" width="75" height="3" rx="1.5" fill="var(--ink-4)" opacity="0.5"/>
          <rect x="44" y="119" width="60" height="2.5" rx="1.25" fill="var(--line)"/>
          <rect x="24" y="132" width="14" height="14" rx="2" fill="var(--line)" stroke="var(--win-line)" stroke-width="0.6"/>
          <rect x="44" y="135" width="65" height="3" rx="1.5" fill="var(--ink-4)" opacity="0.5"/>
          <rect x="44" y="141" width="50" height="2.5" rx="1.25" fill="var(--line)"/>
          {{!-- Dragged file --}}
          <g transform="translate(195, 75) rotate(8)">
            <rect x="0" y="0" width="68" height="52" rx="5" fill="var(--bg)" stroke="var(--accent)" stroke-width="1.4" opacity="0.9"/>
            <path d="M24 32V18l20-4v14" stroke="var(--accent)" stroke-width="1.4" stroke-linecap="round"/>
            <circle cx="21" cy="32" r="4" fill="var(--accent)" opacity="0.6"/>
            <circle cx="41" cy="28" r="3.5" fill="var(--accent)" opacity="0.6"/>
            <text x="34" y="47" text-anchor="middle" fill="var(--ink-3)" font-size="7" font-family="'JetBrains Mono', monospace">.mp3</text>
