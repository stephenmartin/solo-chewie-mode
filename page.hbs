{{!< default}}

{{#post}}

<main class="gh-main gh-outer">
    <div class="gh-inner">
        <article class="gh-article {{post_class}}">
            {{#match @page.show_title_and_feature_image}}
                <header class="gh-article-header gh-canvas">
                    <h1 class="gh-article-title">{{title}}</h1>
                    <img class="gh-page-star" src="{{asset "images/four-dots.svg"}}" alt="">
                    {{> "feature-image"}}
                </header>
            {{/match}}

            <section class="gh-content gh-canvas">
                {{content}}
                <img class="gh-content-star" src="{{asset "images/little-star.svg"}}" alt="">
            </section>
        </article>

        {{#get "posts" filter="tag:project-notes+tag:{{slug}}" limit="all" order="published_at desc"}}
            {{#if posts}}
            <div class="gh-projects">
                <ul class="gh-projects-list">
                    <li class="gh-projects-heading">related posts</li>
                    {{#foreach posts}}
                    <li class="gh-projects-item">
                        <a class="gh-projects-link" href="{{url}}">{{title}}</a>
                    </li>
                    {{/foreach}}
                </ul>
            </div>
            {{/if}}
        {{/get}}
    </div>
</main>

{{/post}}